# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
NEXT_PUBLIC_STRIPE_PRICE_ID_MONTHLY=price_xxx

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPPORT_EMAIL=support@uttr.app
NEXT_PUBLIC_DOWNLOAD_URL=https://github.com/nodatall/uttr/releases/latest

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=sb_service_role_xxx

# Groq proxy
GROQ_API_KEY=gsk_xxx
GROQ_TRANSCRIPTION_MODEL_DEFAULT=whisper-large-v3
UTTR_INSTALL_TOKEN_SECRET=replace-with-a-long-random-secret
UTTR_CLAIM_TOKEN_SECRET=replace-with-a-long-random-secret

# Email notifications (optional for local dev; required in production)
RESEND_API_KEY=re_xxx
EMAIL_FROM="Uttr <noreply@uttr.app>"
EMAIL_SUPPORT=support@uttr.app
